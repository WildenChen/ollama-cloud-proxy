PORT=11435

KEY_ENCRYPTION_SECRET=change-this-very-long-random-secret

# Optional bootstrap/fallback admin token.
# If omitted and the database has no admin password yet, /admin lets you set the first admin password.
ADMIN_TOKEN=change-this-admin-token

# Optional env fallback client tokens. Prefer managing client API keys in the Admin UI.
# Required when exposing /v1/* through the Internet unless DB client keys are configured.
# Format: clientName:token,clientName2:token2
CLIENT_API_KEYS=openclaw:change-this-openclaw-token,kilo-company:change-this-kilo-token

OLLAMA_UPSTREAM_BASE_URL=https://ollama.com
OLLAMA_WEB_BASE_URL=https://ollama.com
OLLAMA_WEB_SEARCH_PATH=/api/web_search
OLLAMA_WEB_FETCH_PATH=/api/web_fetch
OLLAMA_WEB_TIMEOUT_MS=30000
OLLAMA_CLOUD_USAGE_URL=https://ollama.com/settings
# Optional single-account fallback. Prefer per-key Admin UI usage cookies for multi-account pools.
# OLLAMA_USAGE_COOKIE=__Secure-session=...
# OLLAMA_CLOUD_USAGE_COOKIE=__Secure-session=...
OLLAMA_USAGE_REFRESH_TTL_SECONDS=300

MAX_CONCURRENT_REQUESTS=5
MAX_CONCURRENT_REQUESTS_PER_KEY=1
REQUEST_QUEUE_MAX=30
REQUEST_QUEUE_TIMEOUT_MS=120000

UPSTREAM_TOTAL_TIMEOUT_MS=900000
UPSTREAM_IDLE_TIMEOUT_MS=180000
MAX_REQUEST_BODY_SIZE_MB=20
KEY_RETRY_POLICY=smart
KEY_SELECTION_MODE=ordered
MAX_KEY_ATTEMPTS_PER_REQUEST=all
MAX_NETWORK_RETRY_ATTEMPTS=3
MODELS_CACHE_TTL_SECONDS=3600
MODEL_ALIASES_JSON={}
OLLAMA_COMPAT_DISCOVERY_PUBLIC=true
OLLAMA_NATIVE_APPLY_ALIASES=true

USAGE_TIMEZONE=Asia/Taipei
SESSION_RESET_MODE=fixed_anchor
SESSION_RESET_ANCHOR=2026-06-06T20:00:00.000Z
SESSION_RESET_INTERVAL_HOURS=5
WEEKLY_RESET_MODE=fixed_weekly
WEEKLY_RESET_DAY_OF_WEEK=1
WEEKLY_RESET_TIME=08:30
WEEKLY_RESET_GRACE_MINUTES=5
WEEKLY_REACTIVATION_JITTER_SECONDS=180

EVENT_RETENTION_DAYS=14
MAX_EVENTS=100000

LOG_LEVEL=info
DB_PATH=/data/ollama-cloud-proxy.sqlite
